POSTGRES_DB=mentriq360
POSTGRES_USER=mentriq360
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_DEBUG=True
DJANGO_USE_SQLITE=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
DJANGO_ACCESS_TOKEN_MINUTES=30
DJANGO_REFRESH_TOKEN_DAYS=7
DJANGO_CACHE_URL=
DJANGO_THROTTLE_ANON_RATE=30/minute
DJANGO_THROTTLE_USER_RATE=300/minute
DJANGO_THROTTLE_AUTH_RATE=10/minute
DJANGO_THROTTLE_HARDWARE_CAPTURE_RATE=1200/minute

NEXT_PUBLIC_APP_NAME=Mentriq360
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_TIMEOUT_MS=20000
NEXT_PUBLIC_SESSION_IDLE_MINUTES=30
NEXT_PUBLIC_SESSION_VALIDATE_SECONDS=300
