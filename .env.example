# Per-school payment and communication production secrets are configured inside
# the protected ERP UI and are encrypted at rest:
# - Payment Gateway Config: Razorpay key id, key secret, webhook secret, UPI ID
# - Communication Setting: SMTP/SMS/WhatsApp API URLs, keys, secrets, sender IDs
#
# Phase 8 demo data uses the management command below and does not require
# committed environment secrets:
# python backend/manage.py seed_demo_school

NEXT_PUBLIC_APP_NAME=Mentriq360
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Production example: NEXT_PUBLIC_API_BASE_URL=https://your-backend-domain.vercel.app/api/v1
