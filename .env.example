# ═══════════════════════════════════════════════════════════════════════════════
# WARNING: Never commit the actual .env file to version control.
# This .env.example is a template — copy it to .env and fill in real values.
# Keep .env listed in .gitignore and rotate all secrets if exposed.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Django Core ──────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=generate-with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.*
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000
DJANGO_USE_X_FORWARDED_HOST=False
DJANGO_LOG_LEVEL=INFO

# ─── MongoDB (Primary Database) ──────────────────────────────────────────
# PRODUCTION: Use a read-only user where possible, restrict network access
# to trusted IPs via Atlas Network Access, and NEVER use tlsAllowInvalidCertificates.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<cluster>&retryWrites=true&w=majority&tls=true
MONGODB_DATABASE=mentriq360

# ─── Authentication & JWT ────────────────────────────────────────────────
DJANGO_ACCESS_TOKEN_MINUTES=30
DJANGO_REFRESH_TOKEN_DAYS=7
DJANGO_THROTTLE_ANON_RATE=30/minute
DJANGO_THROTTLE_USER_RATE=300/minute
DJANGO_THROTTLE_AUTH_RATE=10/minute
DJANGO_THROTTLE_CHANGE_PASSWORD_RATE=3/minute
DJANGO_THROTTLE_PASSWORD_RESET_RATE=3/minute
DJANGO_THROTTLE_CAPTCHA_RATE=30/minute
DJANGO_THROTTLE_HARDWARE_CAPTURE_RATE=1200/minute
DJANGO_THROTTLE_PAYMENT_RATE=120/minute
DJANGO_THROTTLE_AI_GENERATION_RATE=20/minute
DJANGO_THROTTLE_USER_CREATION_RATE=10/hour

# ─── Super Admin ─────────────────────────────────────────────────────────
MENTRIQ_SUPER_ADMIN_USERNAME=super.admin
MENTRIQ_SUPER_ADMIN_EMAIL=super.admin@mentriq360.local
MENTRIQ_SUPER_ADMIN_PASSWORD=change-me-to-a-strong-password

# ─── Password & Token Expiry ─────────────────────────────────────────────
MENTRIQ_PASSWORD_RESET_TOKEN_MINUTES=30
MENTRIQ_VERIFICATION_TOKEN_HOURS=48
MENTRIQ_PASSWORD_EXPIRY_DAYS=90

# ─── AI / ML ─────────────────────────────────────────────────────────────
MENTRIQ_AI_PROVIDER=local
MENTRIQ_AI_MODEL=role-scoped-summary
MENTRIQ_AI_API_KEY=

# ─── File Uploads ────────────────────────────────────────────────────────
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=
DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
MENTRIQ_UPLOAD_LOGO_MAX_BYTES=524288
MENTRIQ_UPLOAD_BANNER_MAX_BYTES=1048576
MENTRIQ_UPLOAD_PHOTO_MAX_BYTES=2097152
MENTRIQ_UPLOAD_DOCUMENT_MAX_BYTES=5242880
MENTRIQ_UPLOAD_ACADEMIC_MAX_BYTES=10485760

# ─── Caching ──────────────────────────────────────────────────────────────
DJANGO_CACHE_URL=
DJANGO_LOCAL_USE_REDIS=False

# ─── Pagination ──────────────────────────────────────────────────────────
DJANGO_PAGE_SIZE=50
DJANGO_MAX_PAGE_SIZE=200

# ─── Multi-Tenant ────────────────────────────────────────────────────────
DJANGO_TENANT_DOMAIN_SUFFIX=
DJANGO_TENANT_ROUTED_APPS=admin,auth,contenttypes,sessions,token_blacklist,accounts,core

# ─── Security Logging ────────────────────────────────────────────────────
DJANGO_SECURITY_LOG_FILE=/var/log/mentriq/security.log
DJANGO_SECURE_SSL_REDIRECT=True

# ─── Ports ────────────────────────────────────────────────────────────────
DJANGO_PORT=8000
DJANGO_HOST=0.0.0.0
